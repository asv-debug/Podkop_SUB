#!/bin/ash

set -u

json_escape() {
    awk 'BEGIN { ORS="" }
    {
        gsub(/\\/,"\\\\")
        gsub(/"/,"\\\"")
        gsub(/\t/,"\\t")
        gsub(/\r/,"\\r")
        gsub(/\n/,"\\n")
        print
    }'
}

json_string() {
    printf '"%s"' "$(printf '%s' "$1" | json_escape)"
}

json_error() {
    printf '{"success":false,"error":'
    json_string "$1"
    printf '}\n'
}

url_decode() {
    local encoded="$1"
    printf '%b' "$(echo "$encoded" | sed 's/+/ /g; s/%/\\x/g')"
}

url_get_scheme() {
    local url="$1"
    echo "${url%%://*}"
}

url_get_userinfo() {
    local url="$1"
    echo "$url" | sed -n -e 's#^[^:/?]*://##' -e '/@/!d' -e 's/@.*//p'
}

url_get_host() {
    local url="$1"

    url="${url#*://}"
    url="${url#*@}"
    url="${url%%[/?#]*}"

    echo "${url%%:*}"
}

url_get_port() {
    local url="$1"

    url="${url#*://}"
    url="${url#*@}"
    url="${url%%[/?#]*}"

    [ "$url" != "${url#*:}" ] && echo "${url#*:}" || echo ""
}

url_get_fragment() {
    local url="$1"

    [ "$url" != "${url#*#}" ] && echo "${url#*#}" || echo ""
}

url_strip_fragment() {
    local url="$1"
    echo "${url%%#*}"
}

url_escape_fragment() {
    local value="$1"

    printf '%s' "$value" |
        sed \
            -e 's/%/%25/g' \
            -e 's/ /%20/g' \
            -e 's/#/%23/g' \
            -e 's/&/%26/g'
}

json_get_string_field() {
    local json="$1"
    local key="$2"

    printf '%s' "$json" |
        awk -v key="\"$key\"" '
            {
                pos = index($0, key)
                if (!pos) {
                    exit
                }
                value = substr($0, pos + length(key))
                sub(/^[[:space:]]*:[[:space:]]*"/, "", value)
                sub(/".*/, "", value)
                print value
                exit
            }
        '
}

json_get_number_field() {
    local json="$1"
    local key="$2"

    printf '%s' "$json" |
        awk -v key="\"$key\"" '
            {
                pos = index($0, key)
                if (!pos) {
                    exit
                }
                value = substr($0, pos + length(key))
                sub(/^[[:space:]]*:[[:space:]]*/, "", value)
                sub(/[^0-9].*/, "", value)
                print value
                exit
            }
        '
}

base64_decode() {
    local str="$1"
    echo "$str" | base64 -d 2> /dev/null
}

base64_decode_file() {
    local input_file="$1"
    local output_file="$2"

    local encoded remainder
    encoded="$(tr -d '[:space:]' < "$input_file" | tr '_-' '/+')"

    [ -z "$encoded" ] && return 1

    remainder=$((${#encoded} % 4))
    case "$remainder" in
    0) ;;
    2) encoded="${encoded}==" ;;
    3) encoded="${encoded}=" ;;
    *) return 1 ;;
    esac

    printf '%s' "$encoded" | base64 -d > "$output_file" 2> /dev/null
}

is_shadowsocks_userinfo_format() {
    local str="$1"
    local regex='^[^:]+:[^:]+(:[^:]+)?$'

    [ -n "$str" ] && echo "$str" | grep -Eq "$regex"
}

is_valid_port_number() {
    local port="$1"

    case "$port" in
    '' | *[!0-9]*) return 1 ;;
    esac

    [ "$port" -ge 1 ] 2> /dev/null && [ "$port" -le 65535 ] 2> /dev/null
}

is_valid_hysteria2_port() {
    local port="$1"
    local entry start end

    [ -n "$port" ] || return 1

    echo "$port" | tr ',' '\n' | while IFS= read -r entry; do
        entry="$(echo "$entry" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
        [ -n "$entry" ] || exit 1

        case "$entry" in
        *-*)
            case "$entry" in
            *-*-*) exit 1 ;;
            esac
            start="${entry%-*}"
            end="${entry#*-}"
            is_valid_port_number "$start" || exit 1
            is_valid_port_number "$end" || exit 1
            [ "$start" -le "$end" ] 2> /dev/null || exit 1
            ;;
        *)
            is_valid_port_number "$entry" || exit 1
            ;;
        esac
    done
}

is_proxy_url() {
    local url="$1"
    local scheme host port userinfo decoded_userinfo

    url="$(url_decode "$url")"
    url="$(url_strip_fragment "$url")"
    scheme="$(url_get_scheme "$url")"

    case "$scheme" in
    vless | ss | trojan | socks4 | socks4a | socks5 | hysteria2 | hy2) ;;
    *) return 1 ;;
    esac

    host="$(url_get_host "$url")"
    port="$(url_get_port "$url")"

    [ -n "$host" ] || return 1
    case "$scheme" in
    hysteria2 | hy2)
        is_valid_hysteria2_port "$port" || return 1
        ;;
    *)
        is_valid_port_number "$port" || return 1
        ;;
    esac

    case "$scheme" in
    vless | trojan | hysteria2 | hy2)
        [ -n "$(url_get_userinfo "$url")" ] || return 1
        ;;
    ss)
        userinfo="$(url_get_userinfo "$url")"
        [ -n "$userinfo" ] || return 1
        if ! is_shadowsocks_userinfo_format "$userinfo"; then
            decoded_userinfo="$(base64_decode "$userinfo")"
            is_shadowsocks_userinfo_format "$decoded_userinfo" || return 1
        fi
        ;;
    esac

    return 0
}

load_podkop_probe_helpers() {
    [ -r /usr/lib/podkop/helpers.sh ] || return 1
    [ -r /usr/lib/podkop/sing_box_config_manager.sh ] || return 1
    [ -r /usr/lib/podkop/sing_box_config_facade.sh ] || return 1
    command -v sing-box > /dev/null 2>&1 || return 1
    command -v curl > /dev/null 2>&1 || return 1
    command -v jq > /dev/null 2>&1 || return 1

    . /usr/lib/podkop/helpers.sh
    . /usr/lib/podkop/sing_box_config_manager.sh
    . /usr/lib/podkop/sing_box_config_facade.sh
}

get_probe_port() {
    echo $((19090 + ($$ % 1000)))
}

get_probe_inbound_port() {
    local controller_port="$1"
    local index="$2"

    echo $((controller_port + index))
}

is_ipv4_address() {
    local value="$1"
    local old_ifs part count

    old_ifs="$IFS"
    IFS=.
    set -- $value
    IFS="$old_ifs"

    count=0
    for part in "$@"; do
        count=$((count + 1))
        case "$part" in
        '' | *[!0-9]*) return 1 ;;
        esac
        [ "$part" -ge 0 ] 2> /dev/null && [ "$part" -le 255 ] 2> /dev/null || return 1
    done

    [ "$count" -eq 4 ]
}

resolve_ipv4_host() {
    local host="$1"

    is_ipv4_address "$host" && {
        printf '%s' "$host"
        return 0
    }

    nslookup "$host" 2> /dev/null |
        awk '
            function valid_ip(value) {
                return value ~ /^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$/
            }
            /^Address[[:space:]]+[0-9]+:/ {
                if (valid_ip($3)) {
                    print $3
                    exit
                }
            }
            /^Address:/ {
                if ($2 !~ /#/ && valid_ip($2)) {
                    print $2
                    exit
                }
            }
        '
}

replace_proxy_url_host() {
    local url="$1"
    local host="$2"
    local scheme rest authority suffix userinfo hostport port

    scheme="${url%%://*}"
    rest="${url#*://}"
    authority="${rest%%[/?#]*}"
    suffix="${rest#$authority}"

    case "$authority" in
    *@*)
        userinfo="${authority%@*}@"
        hostport="${authority##*@}"
        ;;
    *)
        userinfo=""
        hostport="$authority"
        ;;
    esac

    case "$hostport" in
    *:*) port=":${hostport##*:}" ;;
    *) port="" ;;
    esac

    printf '%s://%s%s%s%s' "$scheme" "$userinfo" "$host" "$port" "$suffix"
}

prepare_probe_link() {
    local link="$1"
    local host security sni resolved

    host="$(url_get_host "$link")"
    [ -n "$host" ] || {
        printf '%s' "$link"
        return 0
    }

    security="$(url_get_query_param "$link" "security")"
    sni="$(url_get_query_param "$link" "sni")"
    case "$security" in
    tls | reality)
        [ -n "$sni" ] || {
            printf '%s' "$link"
            return 0
        }
        ;;
    esac

    resolved="$(resolve_ipv4_host "$host")"
    if [ -n "$resolved" ] && [ "$resolved" != "$host" ]; then
        replace_proxy_url_host "$link" "$resolved"
        return 0
    fi

    printf '%s' "$link"
}

seconds_to_ms() {
    local seconds="$1"

    echo "$seconds" |
        awk '
            /^[0-9]+(\.[0-9]+)?$/ {
                if ($1 <= 0) {
                    exit 1
                }
                ms = int(($1 * 1000) + 0.5)
                if (ms < 1) {
                    ms = 1
                }
                print ms
                ok = 1
            }
            END {
                if (!ok) {
                    exit 1
                }
            }
        '
}

probe_curl_latency() {
    local mode="$1"
    local proxy="$2"
    local output status elapsed latency

    case "$mode" in
    http)
        output="$(
            curl -f -s -o /dev/null \
                --connect-timeout 3 \
                --max-time 12 \
                -x "$proxy" \
                -w '%{http_code} %{time_total}' \
                "https://www.gstatic.com/generate_204" 2> /dev/null
        )" || return 1
        ;;
    socks)
        output="$(
            curl -f -s -o /dev/null \
                --connect-timeout 3 \
                --max-time 12 \
                --socks5-hostname "$proxy" \
                -w '%{http_code} %{time_total}' \
                "https://www.gstatic.com/generate_204" 2> /dev/null
        )" || return 1
        ;;
    *) return 1 ;;
    esac

    status="${output%% *}"
    elapsed="${output#* }"
    case "$status" in
    2* | 3*) ;;
    *) return 1 ;;
    esac

    latency="$(seconds_to_ms "$elapsed" 2> /dev/null)" || return 1
    printf '%s' "$latency"
}

probe_inbound_latency() {
    local inbound_port="$1"
    local latency

    latency="$(probe_curl_latency "http" "http://127.0.0.1:$inbound_port")" && {
        printf '%s' "$latency"
        return 0
    }

    latency="$(probe_curl_latency "socks" "127.0.0.1:$inbound_port")" && {
        printf '%s' "$latency"
        return 0
    }

    return 1
}

build_probe_config() {
    local links_file="$1"
    local controller_port="$2"
    local config_file="$3"
    local config link probe_link index inbound_port inbound_tag outbound_tag

    config='{"log":{},"dns":{},"ntp":{},"certificate":{},"endpoints":[],"inbounds":[],"outbounds":[],"route":{},"services":[],"experimental":{}}'
    config="$(sing_box_cm_configure_log "$config" true "error" false)" || return 1
    config="$(sing_box_cm_configure_dns "$config" "probe-dns" "ipv4_only" true)" || return 1
    config="$(sing_box_cm_add_direct_outbound "$config" "direct-out")" || return 1
    config="$(sing_box_cm_add_udp_dns_server "$config" "probe-dns" "1.1.1.1" 53 "" "")" || return 1
    config="$(sing_box_cm_configure_route "$config" "direct-out" true "probe-dns" "")" || return 1

    index=1
    while IFS= read -r link; do
        [ -n "$link" ] || continue
        inbound_tag="probe-$index-in"
        inbound_port="$(get_probe_inbound_port "$controller_port" "$index")"
        outbound_tag="probe-$index-out"
        probe_link="$(prepare_probe_link "$link")"
        config="$(sing_box_cf_add_proxy_outbound "$config" "probe-$index" "$probe_link" "")" || return 1
        config="$(sing_box_cf_add_mixed_inbound_and_route_rule "$config" "$inbound_tag" "127.0.0.1" "$inbound_port" "$outbound_tag")" || return 1
        index=$((index + 1))
    done < "$links_file"

    [ "$index" -gt 1 ] || return 1

    sing_box_cm_save_config_to_file "$config" "$config_file" || return 1
    sing-box -c "$config_file" check > /dev/null 2>&1
}

run_probe_config() {
    local config_file="$1"
    local controller_port="$2"
    local links_file="$3"
    local response_file="$4"
    local log_file result_dir pid index link tag inbound_port latency tmpfile

    log_file="$(mktemp)"
    sing-box run -c "$config_file" > /dev/null 2> "$log_file" &
    pid="$!"

    sleep 1

    result_dir="/tmp/podkop-subscriptions-probe.$$"
    rm -rf "$result_dir"
    mkdir -p "$result_dir" || {
        kill "$pid" > /dev/null 2>&1 || true
        wait "$pid" > /dev/null 2>&1 || true
        rm -f "$log_file"
        return 1
    }

    index=1
    while IFS= read -r link; do
        [ -n "$link" ] || continue
        tag="probe-$index-out"
        inbound_port="$(get_probe_inbound_port "$controller_port" "$index")"
        latency="$(probe_inbound_latency "$inbound_port" 2> /dev/null || true)"
        case "$latency" in
        '' | null | *[!0-9]*) ;;
        *) printf '%s\n' "$latency" > "$result_dir/$index" ;;
        esac

        index=$((index + 1))
    done < "$links_file"

    kill "$pid" > /dev/null 2>&1 || true
    wait "$pid" > /dev/null 2>&1 || true
    rm -f "$log_file"

    printf '{}\n' > "$response_file"
    index=1
    while IFS= read -r link; do
        [ -n "$link" ] || continue
        tag="probe-$index-out"
        latency="$(cat "$result_dir/$index" 2> /dev/null || true)"
        case "$latency" in
        '' | null | *[!0-9]*) ;;
        *)
            tmpfile="$(mktemp)"
            jq --arg tag "$tag" --argjson latency "$latency" \
                '. + {($tag): $latency}' "$response_file" > "$tmpfile" &&
                mv "$tmpfile" "$response_file"
            rm -f "$tmpfile"
            ;;
        esac
        index=$((index + 1))
    done < "$links_file"
    rm -rf "$result_dir"

    jq -e 'type == "object" and length > 0' "$response_file" > /dev/null 2>&1
}

probe_links_latency_to_file() {
    local links_file="$1"
    local response_file="$2"
    local controller_port config_file

    load_podkop_probe_helpers || return 1

    controller_port="$(get_probe_port)"
    config_file="$(mktemp)"

    if ! build_probe_config "$links_file" "$controller_port" "$config_file"; then
        rm -f "$config_file"
        return 1
    fi

    if ! run_probe_config "$config_file" "$controller_port" "$links_file" "$response_file"; then
        rm -f "$config_file"
        return 1
    fi

    rm -f "$config_file"
}

json_latency_result_for_index() {
    local response_file="$1"
    local index="$2"
    local tag latency

    tag="probe-$index-out"
    latency="$(jq -r --arg tag "$tag" '.[$tag] // empty' "$response_file" 2> /dev/null)"

    case "$latency" in
    '' | null | *[!0-9]*)
        printf '"success":false,"error":'
        json_string "Ping failed"
        ;;
    *)
        printf '"success":true,"latency_ms":'
        json_string "$latency"
        ;;
    esac
}

section_has_backend_outbound() {
    local section="$1"

    [ -n "$(uci -q get "podkop.$section.proxy_string")" ] && return 0
    [ -n "$(uci -q get "podkop.$section.selector_proxy_links")" ] && return 0
    [ -n "$(uci -q get "podkop.$section.urltest_proxy_links")" ] && return 0
    [ -n "$(uci -q get "podkop.$section.outbound_json")" ] && return 0
    [ -n "$(uci -q get "podkop.$section.interface")" ] && return 0

    return 1
}

ensure_subscription_backend_outbound() {
    local section="$1"
    local links_file="$2"
    local selected first_link

    selected="$(uci -q get "podkop.$section.subscription_selected_proxy_link")"
    if [ -n "$selected" ]; then
        uci set "podkop.$section.proxy_config_type=selector"
        uci -q delete "podkop.$section.selector_proxy_links"
        uci add_list "podkop.$section.selector_proxy_links=$selected"
        return
    fi

    if section_has_backend_outbound "$section"; then
        return
    fi

    first_link="$(sed -n '/./{p;q}' "$links_file")"
    [ -n "$first_link" ] || return

    uci set "podkop.$section.proxy_config_type=selector"
    uci set "podkop.$section.subscription_selected_proxy_link=$first_link"
    uci -q delete "podkop.$section.selector_proxy_links"
    uci add_list "podkop.$section.selector_proxy_links=$first_link"
}

convert_crlf_to_lf() {
    local filepath="$1"
    local tmpfile

    if grep -q "$(printf '\r')" "$filepath"; then
        tmpfile="$(mktemp)"
        tr -d '\r' < "$filepath" > "$tmpfile" && mv "$tmpfile" "$filepath" || rm -f "$tmpfile"
    fi
}

extract_proxy_urls_from_file() {
    local input_file="$1"
    local output_file="$2"
    local normalized_file

    normalized_file="$(mktemp)"
    sed 's#\\/#/#g; s#\\u0026#\&#g' "$input_file" > "$normalized_file"

    grep -Eo "(vless|ss|trojan|socks4|socks4a|socks5|hysteria2|hy2)://[^[:space:]'\"<>]+" "$normalized_file" |
        sed 's/[[:cntrl:]]//g' |
        sed 's/[]}),;]*$//' |
        while IFS= read -r line; do
            if is_proxy_url "$line"; then
                echo "$line"
            fi
        done |
        awk '!seen[$0]++' > "$output_file"

    rm -f "$normalized_file"
}

extract_proxy_urls_from_base64_chunks() {
    local input_file="$1"
    local output_file="$2"

    grep -Eo '[A-Za-z0-9_-]{32,}={0,2}' "$input_file" |
        head -n 200 |
        while IFS= read -r token; do
            token_file="$(mktemp)"
            decoded_file="$(mktemp)"
            urls_file="$(mktemp)"

            printf '%s' "$token" > "$token_file"

            if base64_decode_file "$token_file" "$decoded_file"; then
                extract_proxy_urls_from_file "$decoded_file" "$urls_file"
                [ -s "$urls_file" ] && cat "$urls_file"
            fi

            rm -f "$token_file" "$decoded_file" "$urls_file"
        done |
        awk '!seen[$0]++' > "$output_file"
}

extract_v2ray_json_proxy_links() {
    local input_file="$1"
    local output_file="$2"
    local normalized_file entry proxy_part protocol host port id encryption flow network security sni fp pbk sid path ws_host remarks query link

    normalized_file="$(mktemp)"
    tr -d '\r\n' < "$input_file" |
        awk '{ gsub(/\},[[:space:]]*\{"dns"/, "}\n{\"dns\""); print }' > "$normalized_file"

    : > "$output_file"

    while IFS= read -r entry; do
        case "$entry" in
        *'"outbounds"'*'"protocol"'*) ;;
        *) continue ;;
        esac

        proxy_part="${entry#*\"outbounds\":}"
        protocol="$(json_get_string_field "$proxy_part" "protocol")"

        case "$protocol" in
        vless) ;;
        *) continue ;;
        esac

        host="$(json_get_string_field "$proxy_part" "address")"
        port="$(json_get_number_field "$proxy_part" "port")"
        id="$(json_get_string_field "$proxy_part" "id")"
        encryption="$(json_get_string_field "$proxy_part" "encryption")"
        flow="$(json_get_string_field "$proxy_part" "flow")"
        network="$(json_get_string_field "$proxy_part" "network")"
        security="$(json_get_string_field "$proxy_part" "security")"
        sni="$(json_get_string_field "$proxy_part" "serverName")"
        fp="$(json_get_string_field "$proxy_part" "fingerprint")"
        pbk="$(json_get_string_field "$proxy_part" "publicKey")"
        sid="$(json_get_string_field "$proxy_part" "shortId")"
        path="$(json_get_string_field "$proxy_part" "path")"
        ws_host="$(json_get_string_field "$proxy_part" "Host")"
        remarks="$(json_get_string_field "$entry" "remarks")"

        [ -n "$host" ] || continue
        is_valid_port_number "$port" || continue
        [ -n "$id" ] || continue

        [ -n "$encryption" ] || encryption="none"
        [ -n "$network" ] || network="tcp"
        [ -n "$security" ] || security="none"

        query="encryption=$encryption"
        [ -n "$flow" ] && query="$query&flow=$flow"
        [ -n "$network" ] && query="$query&type=$network"
        [ -n "$security" ] && query="$query&security=$security"
        [ -n "$sni" ] && query="$query&sni=$sni"
        [ -n "$fp" ] && query="$query&fp=$fp"
        [ -n "$pbk" ] && query="$query&pbk=$pbk"
        [ -n "$sid" ] && query="$query&sid=$sid"
        [ -n "$path" ] && query="$query&path=$(url_escape_fragment "$path")"
        [ -n "$ws_host" ] && query="$query&host=$ws_host"

        link="vless://$id@$host:$port?$query"
        [ -n "$remarks" ] && link="$link#$(url_escape_fragment "$remarks")"

        if is_proxy_url "$link"; then
            echo "$link" >> "$output_file"
        fi
    done < "$normalized_file"

    if [ -s "$output_file" ]; then
        awk '!seen[$0]++' "$output_file" > "$normalized_file"
        mv "$normalized_file" "$output_file"
        return 0
    fi

    rm -f "$normalized_file"
    return 1
}

extract_proxy_links_from_subscription_file() {
    local subscription_file="$1"
    local output_file="$2"
    local decoded_file extracted_file chunk_file json_file

    decoded_file="$(mktemp)"
    extracted_file="$(mktemp)"
    chunk_file="$(mktemp)"
    json_file="$(mktemp)"

    convert_crlf_to_lf "$subscription_file"
    extract_proxy_urls_from_file "$subscription_file" "$extracted_file"
    extract_proxy_urls_from_base64_chunks "$subscription_file" "$chunk_file"
    [ -s "$chunk_file" ] && cat "$chunk_file" >> "$extracted_file"
    if [ ! -s "$extracted_file" ] && extract_v2ray_json_proxy_links "$subscription_file" "$json_file"; then
        cat "$json_file" >> "$extracted_file"
    fi

    if [ ! -s "$extracted_file" ] && base64_decode_file "$subscription_file" "$decoded_file"; then
        convert_crlf_to_lf "$decoded_file"
        extract_proxy_urls_from_file "$decoded_file" "$extracted_file"
        extract_proxy_urls_from_base64_chunks "$decoded_file" "$chunk_file"
        [ -s "$chunk_file" ] && cat "$chunk_file" >> "$extracted_file"
        if [ ! -s "$extracted_file" ] && extract_v2ray_json_proxy_links "$decoded_file" "$json_file"; then
            cat "$json_file" >> "$extracted_file"
        fi
    fi

    if [ -s "$extracted_file" ]; then
        awk '!seen[$0]++' "$extracted_file" > "$output_file"
        rm -f "$decoded_file" "$extracted_file" "$chunk_file" "$json_file"
        return 0
    fi

    rm -f "$decoded_file" "$extracted_file" "$chunk_file" "$json_file"
    return 1
}

download_subscription_to_file() {
    local url="$1"
    local filepath="$2"
    local user_agent="$3"

    rm -f "$filepath"

    if command -v curl > /dev/null 2>&1; then
        curl -fL --compressed \
            --connect-timeout 15 \
            --max-time 45 \
            -A "$user_agent" \
            -H "Accept: text/plain, application/json, application/yaml, */*" \
            -o "$filepath" \
            "$url" > /dev/null 2>&1
        return $?
    fi

    wget -q -U "$user_agent" -O "$filepath" "$url" > /dev/null 2>&1 ||
        wget -q --user-agent="$user_agent" -O "$filepath" "$url" > /dev/null 2>&1 ||
        wget -q -O "$filepath" "$url" > /dev/null 2>&1
}

try_import_subscription_url() {
    local url="$1"
    local user_agent="$2"
    local output_file="$3"
    local tmpfile links_tmpfile

    tmpfile="$(mktemp)"
    links_tmpfile="$(mktemp)"

    if download_subscription_to_file "$url" "$tmpfile" "$user_agent" && [ -s "$tmpfile" ]; then
        if extract_proxy_links_from_subscription_file "$tmpfile" "$links_tmpfile"; then
            cat "$links_tmpfile" >> "$output_file"
            rm -f "$tmpfile" "$links_tmpfile"
            return 0
        fi
    fi

    rm -f "$tmpfile" "$links_tmpfile"
    return 1
}

remove_old_subscription_cron_jobs() {
    local tmpfile

    command -v crontab >/dev/null 2>&1 || return 0

    tmpfile="$(mktemp)"
    if crontab -l > "$tmpfile" 2>/dev/null; then
        grep -v "podkop-subscription-update-" "$tmpfile" | crontab - >/dev/null 2>&1 || true
    fi
    rm -f "$tmpfile"
}

normalize_urls_to_file() {
    local urls="$1"
    local output_file="$2"

    printf '%s\n' "$urls" |
        tr ' ' '\n' |
        sed 's/^[[:space:]]*//;s/[[:space:]]*$//' |
        awk 'NF && !seen[$0]++' > "$output_file"
}

print_servers_json_from_file() {
    local output_file="$1"
    local count index link scheme host port name

    count="$(wc -l < "$output_file" | tr -d ' ')"
    printf '{"success":true,"count":%s,"servers":[' "$count"

    index=1
    while IFS= read -r link; do
        [ -z "$link" ] && continue
        scheme="$(url_get_scheme "$link")"
        host="$(url_get_host "$link")"
        port="$(url_get_port "$link")"
        name="$(url_decode "$(url_get_fragment "$link")")"
        [ -n "$name" ] || name="$scheme://$host:$port"

        [ "$index" -gt 1 ] && printf ','
        printf '{"index":%s,"name":' "$index"
        json_string "$name"
        printf ',"scheme":'
        json_string "$scheme"
        printf ',"host":'
        json_string "$host"
        printf ',"port":'
        json_string "$port"
        printf ',"link":'
        json_string "$link"
        printf '}'
        index=$((index + 1))
    done < "$output_file"

    printf ']}\n'
}

load_subscription_links() {
    local urls="$1"
    local user_agent="${2:-auto}"
    local limit="${3:-30}"
    local output_file="$4"
    local merged_tmpfile urls_tmpfile url ua imported imported_any limited_tmpfile

    [ -n "$urls" ] || return 1

    case "$limit" in
    '' | *[!0-9]*) limit=30 ;;
    esac

    merged_tmpfile="$(mktemp)"
    urls_tmpfile="$(mktemp)"
    : > "$merged_tmpfile"

    normalize_urls_to_file "$urls" "$urls_tmpfile"

    imported_any=1
    while IFS= read -r url; do
        [ -n "$url" ] || continue

        imported=1
        if [ -n "$user_agent" ] && [ "$user_agent" != "auto" ]; then
            if try_import_subscription_url "$url" "$user_agent" "$merged_tmpfile"; then
                imported=0
            fi
        fi

        if [ "$imported" -ne 0 ]; then
            for ua in \
                "sing-box/1.12.0" \
                "v2rayNG/1.9.31" \
                "v2rayN/7.0" \
                "HiddifyNext/2.5.7" \
                "Happ/1.0" \
                "NekoBox/1.3" \
                "ClashMetaForAndroid/2.11.10" \
                "Shadowrocket/2.2.53" \
                "curl/8.0"; do
                [ "$ua" = "$user_agent" ] && continue
                if try_import_subscription_url "$url" "$ua" "$merged_tmpfile"; then
                    imported=0
                    break
                fi
            done
        fi

        [ "$imported" -eq 0 ] && imported_any=0
    done < "$urls_tmpfile"

    rm -f "$urls_tmpfile"

    if [ "$imported_any" -ne 0 ] || [ ! -s "$merged_tmpfile" ]; then
        rm -f "$merged_tmpfile"
        return 1
    fi

    awk '!seen[$0]++' "$merged_tmpfile" > "$output_file"
    rm -f "$merged_tmpfile"

    if [ "$limit" -gt 0 ]; then
        limited_tmpfile="$(mktemp)"
        head -n "$limit" "$output_file" > "$limited_tmpfile"
        mv "$limited_tmpfile" "$output_file"
    fi

    [ -s "$output_file" ]
}

list_servers() {
    local urls="$1"
    local user_agent="${2:-auto}"
    local limit="${3:-30}"
    local output_file

    [ -n "$urls" ] || {
        json_error "Subscription URL is required"
        return 1
    }

    output_file="$(mktemp)"
    if ! load_subscription_links "$urls" "$user_agent" "$limit" "$output_file"; then
        rm -f "$output_file"
        json_error "No supported proxy links found in subscription"
        return 1
    fi

    print_servers_json_from_file "$output_file"
    rm -f "$output_file"
}

sync_subscription() {
    local section="$1"
    local urls="$2"
    local user_agent="${3:-auto}"
    local limit="${4:-30}"
    local output_file urls_tmpfile link url

    [ -n "$section" ] || {
        json_error "Podkop section is required"
        return 1
    }

    [ -n "$urls" ] || {
        json_error "Subscription URL is required"
        return 1
    }

    if ! uci -q show "podkop.$section" > /dev/null 2>&1; then
        json_error "Podkop section does not exist"
        return 1
    fi

    case "$limit" in
    '' | *[!0-9]*) limit=30 ;;
    esac

    output_file="$(mktemp)"
    urls_tmpfile="$(mktemp)"
    if ! load_subscription_links "$urls" "$user_agent" "$limit" "$output_file"; then
        rm -f "$output_file" "$urls_tmpfile"
        json_error "No supported proxy links found in subscription"
        return 1
    fi

    uci set "podkop.$section.connection_type=proxy"
    uci -q delete "podkop.$section.subscription_url"
    uci -q delete "podkop.$section.subscription_urls"
    normalize_urls_to_file "$urls" "$urls_tmpfile"
    while IFS= read -r url; do
        [ -n "$url" ] && uci add_list "podkop.$section.subscription_urls=$url"
    done < "$urls_tmpfile"
    rm -f "$urls_tmpfile"
    uci set "podkop.$section.subscription_user_agent=$user_agent"
    uci set "podkop.$section.subscription_max_servers=$limit"
    uci -q delete "podkop.$section.subscription_proxy_links"
    uci -q delete "podkop.$section.subscription_content"

    while IFS= read -r link; do
        [ -n "$link" ] && uci add_list "podkop.$section.subscription_proxy_links=$link"
    done < "$output_file"

    ensure_subscription_backend_outbound "$section" "$output_file"
    remove_old_subscription_cron_jobs

    uci commit podkop || {
        rm -f "$output_file"
        json_error "Failed to save Podkop configuration"
        return 1
    }

    print_servers_json_from_file "$output_file"
    rm -f "$output_file"
}

apply_server() {
    local section="$1"
    local link="$2"
    local restart_output

    [ -n "$section" ] || {
        json_error "Podkop section is required"
        return 1
    }

    if ! is_proxy_url "$link"; then
        json_error "Selected proxy link is invalid"
        return 1
    fi

    if ! uci -q show "podkop.$section" > /dev/null 2>&1; then
        json_error "Podkop section does not exist"
        return 1
    fi

    uci set "podkop.$section.connection_type=proxy"
    uci set "podkop.$section.proxy_config_type=selector"
    uci set "podkop.$section.subscription_selected_proxy_link=$link"
    uci -q delete "podkop.$section.selector_proxy_links"
    uci add_list "podkop.$section.selector_proxy_links=$link"
    uci -q delete "podkop.$section.proxy_string"
    uci -q delete "podkop.$section.outbound_json"
    uci -q delete "podkop.$section.urltest_proxy_links"
    uci -q delete "podkop.$section.urltest_check_interval"
    uci -q delete "podkop.$section.urltest_tolerance"
    uci -q delete "podkop.$section.urltest_testing_url"
    uci -q delete "podkop.$section.subscription_url"
    uci -q delete "podkop.$section.subscription_content"
    remove_old_subscription_cron_jobs
    uci commit podkop || {
        json_error "Failed to save Podkop configuration"
        return 1
    }

    restart_output="$(/etc/init.d/podkop restart 2>&1)" || {
        json_error "Failed to apply Podkop configuration: $restart_output"
        return 1
    }

    printf '{"success":true}\n'
}

ping_link_latency() {
    local link="$1"
    local links_file response_file latency

    if ! is_proxy_url "$link"; then
        return 1
    fi

    links_file="$(mktemp)"
    response_file="$(mktemp)"
    latency=""
    printf '%s\n' "$link" > "$links_file"

    if probe_links_latency_to_file "$links_file" "$response_file"; then
        latency="$(jq -r '."probe-1-out" // empty' "$response_file" 2> /dev/null)"
    fi

    rm -f "$links_file" "$response_file"
    case "$latency" in
    '' | null | *[!0-9]*) return 1 ;;
    esac
    printf '%s' "$latency"
}

ping_server() {
    local link="$1"
    local latency

    if ! is_proxy_url "$link"; then
        json_error "Selected proxy link is invalid"
        return 1
    fi

    latency="$(ping_link_latency "$link")" || {
        json_error "Ping failed"
        return 1
    }

    printf '{"success":true,"latency_ms":'
    json_string "$latency"
    printf '}\n'
}

ping_servers() {
    local links="$1"
    local links_file response_file index link first probe_success latency tag

    [ -n "$links" ] || {
        json_error "Proxy links are required"
        return 1
    }

    links_file="$(mktemp)"
    response_file="$(mktemp)"
    printf '%s\n' "$links" |
        while IFS= read -r link; do
            [ -n "$link" ] && printf '%s\n' "$link"
        done > "$links_file"

    if [ ! -s "$links_file" ]; then
        rm -f "$links_file" "$response_file"
        json_error "Proxy links are required"
        return 1
    fi

    probe_success=0
    if probe_links_latency_to_file "$links_file" "$response_file"; then
        probe_success=1
    fi

    printf '{"success":true,"results":['
    index=1
    first=1
    while IFS= read -r link; do
        [ -n "$link" ] || continue
        [ "$first" -eq 0 ] && printf ','
        first=0
        printf '{"index":%s,' "$index"
        latency=""
        if [ "$probe_success" -eq 1 ]; then
            tag="probe-$index-out"
            latency="$(jq -r --arg tag "$tag" '.[$tag] // empty' "$response_file" 2> /dev/null)"
        fi

        case "$latency" in
        '' | null | *[!0-9]*)
            latency=""
            ;;
        esac

        if [ -n "$latency" ]; then
            printf '"success":true,"latency_ms":'
            json_string "$latency"
        elif latency="$(ping_link_latency "$link")"; then
            printf '"success":true,"latency_ms":'
            json_string "$latency"
        else
            printf '"success":false,"error":'
            json_string "Ping failed"
        fi
        printf '}'
        index=$((index + 1))
    done < "$links_file"
    printf ']}\n'

    rm -f "$links_file" "$response_file"
}

case "${1:-}" in
list)
    list_servers "${2:-}" "${3:-auto}" "${4:-30}"
    ;;
sync)
    sync_subscription "${2:-}" "${3:-}" "${4:-auto}" "${5:-30}"
    ;;
apply)
    apply_server "${2:-}" "${3:-}"
    ;;
ping)
    ping_server "${2:-}"
    ;;
ping-list)
    ping_servers "${2:-}"
    ;;
*)
    json_error "Usage: podkop-subscriptions {list URL [USER_AGENT] [LIMIT]|sync SECTION URL [USER_AGENT] [LIMIT]|apply SECTION LINK|ping LINK|ping-list LINKS}"
    exit 1
    ;;
esac
